# ───────────────────────────────────────────────────────────
# Flutter / Dart / Pub
# ───────────────────────────────────────────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication
app.*.symbols

# Obfuscation maps
app.*.map.json

# ───────────────────────────────────────────────────────────
# Android
# (detailed rules live in android/.gitignore)
# ───────────────────────────────────────────────────────────
/android/app/debug
/android/app/profile
/android/app/release

# ───────────────────────────────────────────────────────────
# iOS / macOS
# (detailed rules live in ios/.gitignore)
# ───────────────────────────────────────────────────────────
# nothing extra needed here

# ───────────────────────────────────────────────────────────
# Secrets & environment
# ───────────────────────────────────────────────────────────
.env
.env.*
*.env

# ───────────────────────────────────────────────────────────
# FVM (Flutter Version Manager)
# ───────────────────────────────────────────────────────────
.fvm/

# ───────────────────────────────────────────────────────────
# IDEs & editors
# ───────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws

# VS Code — launch configs / tasks may be committed intentionally;
# uncomment the line below to ignore them instead.
#.vscode/

# ───────────────────────────────────────────────────────────
# Miscellaneous
# ───────────────────────────────────────────────────────────
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
